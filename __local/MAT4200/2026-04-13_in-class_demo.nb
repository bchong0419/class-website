   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"vMin", ",", "vMax"}], "}"}], "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"u0", ",", "v0"}], "}"}], "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"c1", "[", "t_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{"t", ",", 
     RowBox[{"t", "+", "1"}]}], "}"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"c2", "[", "t_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", "=", 
        RowBox[{"1", "/", "2.9"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        FractionBox[
         RowBox[{"t", " ", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"a", " ", "t"}]}], ")"}]}], 
         SqrtBox["2"]], ",", 
        RowBox[{"1", "+", 
         FractionBox[
          RowBox[{"t", " ", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"a", " ", "t"}]}], ")"}]}], 
          SqrtBox["2"]]}]}], "}"}]}], "]"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c2", "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], "+", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"t", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", " ", 
        RowBox[{"2", "t"}]}], ")"}]}], ",", 
     RowBox[{"t", " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"2", "t"}]}], ")"}]}]}], "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"curvature", "[", 
    RowBox[{"r_", ",", "t_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r1", ",", "r2"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"r1", "=", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"r", "[", "s", "]"}], ",", "s"}], "]"}], "/.", 
        RowBox[{"s", "->", "t"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"r2", "=", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"r", "[", "s", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"s", ",", "2"}], "}"}]}], "]"}], "/.", 
        RowBox[{"s", "->", "t"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Norm", "[", 
        RowBox[{"Cross", "[", 
         RowBox[{"r1", ",", "r2"}], "]"}], "]"}], "/", 
       RowBox[{
        RowBox[{"Norm", "[", "r1", "]"}], "^", "3"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FrenetT", "[", 
